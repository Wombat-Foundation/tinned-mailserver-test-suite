# Mail server host to test
MAILSERVER_NAME=mail.example.com
HELO_NAME=localhost

# SMTP / IMAP authentication credentials
SENDER_AUTH_USER=test1@example.com
SENDER_AUTH_PASSWORD=TestPassword

# Sender addresses for different tests
SENDER_ADDRESS_MAIN=test1@example.com
SENDER_ADDRESS_ALIAS=test2@example.com
SENDER_ADDRESS_MAIN_TAG=test1+extension@example.com
SENDER_ADDRESS_ALIAS_TAG=test2+tag02@example.com

# Senders for negative/security tests
SENDER_ADDRESS_DENIED=test3@example.com
SENDER_ADDRESS_FORGED=forged@example.com
SENDER_ADDRESS_FORGED2=forged@example.net

# External recipient address for outbound tests
RECIPIENT_ADDRESS=test@example.com
